{
  "App": {
    "SelfUrl": "https://localhost:44300",
    "AngularUrl": "http://localhost:4200",
    "CorsOrigins": "https://*.MovieRental.com,http://localhost:4200,",
    "RedirectAllowedUrls": "http://localhost:4200,",
    "DisablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Data Source=../../MovieRental.db;"
  },
  "AuthServer": {
    "Authority": "https://localhost:44300",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "MovieRental_Swagger",
    "CertificatePassPhrase": "0d94691a-7557-4f13-baaa-a1dbb5ea6888"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "quJc5s0vFvP10ri8"
  }}